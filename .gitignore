# ============================================================
# P25 — .gitignore
# ============================================================

# Virtual environment — never commit this
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Generated outputs — large files, reproducible from scripts
outputs/p25_outputs/*.png
outputs/p25_outputs/*.txt
outputs/p25_outputs/*.csv

# Processed CSVs — reproducible by running p25_data_pipeline.py
data/processed/

# Frozen requirements (generated by pip freeze — not version controlled)
requirements_frozen.txt

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Environment variables
.env
*.env

*.docx
*/*.docx
*.pdf
*/*.pdf

# Pytest
.pytest_cache/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/

# ── KEEP these (commit to git) ──────────────────────────────
# data/raw/communities.data    ← raw dataset 1
# data/raw/communities.names   ← column names
# data/raw/state_crime.csv     ← raw dataset 2
# docs/P25_Project_Reference.docx
# All scripts in scripts/
# requirements.txt
# setup.sh
# README.md
